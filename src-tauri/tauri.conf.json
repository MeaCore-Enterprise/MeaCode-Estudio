{
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "MeaCode Studio",
    "version": "0.0.0"
  },
  "tauri": {
    "windows": [
      {
        "title": "MeaCode Studio",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "bundle": {
      "active": true,
      "targets": [
        "deb",
        "appimage"
      ],
      "identifier": "com.meacore.meacode-studio",
      "category": "Development",
      "shortDescription": "IDE de escritorio IA-first para desarrollo de software.",
      "longDescription": "MeaCode Studio combina editor, terminal y acciones de IA para acelerar flujos de desarrollo en una sola aplicacion de escritorio.",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1",
          "libxdo3",
          "libssl3",
          "libglib2.0-0",
          "libc6"
        ],
        "files": {
          "/usr/share/metainfo/com.meacore.meacode-studio.metainfo.xml": "linux/com.meacore.meacode-studio.metainfo.xml"
        }
      }
    },
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/MeaCore-Enterprise/MeaCode-Studio/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk5MzFBNDQ2RkRBOUU3QTgKUldTbzU2bjlScVF4bVJVZjdNRHJLbHNMdFVyWEY5d0JIc1dWdjV0YXlhOFZTcS9QT1Q1dXhhVU8K"
    }
  }
}
